{
  "name": "cards-words-gaps",
  "version": "0.0.3",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "backend": "node server.js",
    "dev": "concurrently \"npm run backend\" \"npm start\"",
    "build": "ng build",
    "build:prod": "ng build -- --configuration production --base-href=/cards-words-gaps/ --deploy-url=/cards-words-gaps/",
    "deploy": "npm run build:prod && npx angular-cli-ghpages --dir=dist/cards-words-gaps",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.20",
    "@angular/cdk": "~19.2.19",
    "@angular/common": "^19.2.20",
    "@angular/compiler": "^19.2.20",
    "@angular/core": "^19.2.20",
    "@angular/forms": "^19.2.20",
    "@angular/material": "~19.2.19",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^19.2.20",
    "@angular/router": "^19.2.20",
    "@ngxs/store": "^3.8.2",
    "@types/uuid": "^9.0.7",
    "bootstrap": "^5.3.3",
    "rxjs": "~7.8.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tslib": "^2.3.0",
    "uuid": "^9.0.1",
    "zone.js": "~0.15.1",
    "cors": "^2.8.5",
    "express": "5.0.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.22",
    "@angular/cli": "^19.2.22",
    "@angular/compiler-cli": "^19.2.20",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.4",
    "concurrently": "^8.2.2"
  }
}
